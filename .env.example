# ── Orbit Audiobooks Fastlane Environment ─────────────────────
# Copy this to .env and fill in real values.
# .env is git-ignored and safe for secrets.

# Required: fastlane match uses this to encrypt/decrypt the certificates repo.
# Use a long random string. Save it somewhere safe (password manager).
# Set this once and never change it — changing it requires re-encrypting all profiles.
MATCH_PASSWORD=your-match-encryption-password

# Optional: GitHub personal access token (only needed if the certs repo is private
# and you want to use HTTPS instead of SSH, or on CI without SSH keys).
# MATCH_GIT_BASIC_AUTHORIZATION=base64encoded-username:token

# Optional: CI environment — when set, match runs in read-only mode so it
# doesn't accidentally create new certs/profiles on a build machine.
# CI=true
